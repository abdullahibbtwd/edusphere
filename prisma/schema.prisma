generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String              @id @default(cuid())
  name                     String?
  email                    String              @unique
  imageUrl                 String?
  clerkUserId              String?             @unique
  role                     Role                @default(USER)
  schoolId                 String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  isEmailVerified          Boolean             @default(false)
  password                 String
  passwordResetCode        String?
  passwordResetExpires     DateTime?
  announcements            Announcement[]
  events                   Event[]
  schoolApplications       SchoolApplication[]
  studentApplications      StudentApplication?
  student                  Student?
  teacher                  Teacher?
  school                   School?             @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([email])
  @@map("users")
}

model School {
  id                    String                @id @default(cuid())
  name                  String                @unique
  subdomain             String                @unique
  address               String
  pmbNumber             String?
  rcNumber              String?
  schoolType            SchoolType
  principalName         String
  phoneNumber           String
  email                 String
  website               String?
  establishmentYear     String
  ownershipType         OwnershipType
  curriculum            CurriculumType
  totalStudents         Int?
  totalTeachers         Int?
  accreditation         String?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  facilitiesList        Json?
  isAdmissionsOpen      Boolean               @default(true)
  isScreeningEnabled    Boolean               @default(false)
  screeningVenue        String?
  screeningStartTime    String?
  screeningEndTime      String?
  screeningSlotsPerDay  Int?
  academicEvents        AcademicEvent[]
  academicSessions      AcademicSession[]
  academicTerms         AcademicTerm[]
  announcements         Announcement[]
  applicationBookings   ApplicationBooking[]
  classes               Class[]
  events                Event[]
  examTimetables        ExamTimetable[]
  levels                Level[]
  campuses              SchoolCampus[]
  content               SchoolContent?
  facilities            SchoolFacility[]
  subscription          SchoolSubscription?
  screeningSlots        ScreeningSlot[]
  studentApplications   StudentApplication[]
  students              Student[]
  subjects              Subject[]
  teacherSubjectClasses TeacherSubjectClass[]
  teachers              Teacher[]
  timetableConfig       TimetableConfig?
  timetables            Timetable[]
  users                 User[]

  @@map("schools")
}

model SchoolContent {
  id               String   @id @default(cuid())
  schoolId         String   @unique
  heroTitle        String?
  heroSubtitle     String?
  heroImage        String?
  schoolLogo       String?
  description      String?
  contactAddress   String?
  contactPhone     String?
  contactEmail     String?
  facebookUrl      String?
  twitterUrl       String?
  instagramUrl     String?
  linkedinUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  campusImages     Json?
  aboutDescription String?
  aboutImage       String?
  aboutTitle       String?
  bannerImage      String?
  bannerStats      Json?
  bannerTitle      String?
  facilities       Json?
  levelSelection   String?
  softSkills       Json?
  classes          Json?
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_contents")
}

model SchoolFacility {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_facilities")
}

model SchoolCampus {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_campuses")
}

model SchoolSubscription {
  id            String             @id @default(cuid())
  schoolId      String             @unique
  planType      SubscriptionPlan   @default(FREE)
  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now())
  endDate       DateTime
  maxStudents   Int                @default(500)
  maxTeachers   Int                @default(50)
  features      String[]
  amount        Float              @default(0)
  currency      String             @default("USD")
  paymentMethod String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_subscriptions")
}

model SchoolApplication {
  id                  String                  @id @default(cuid())
  schoolName          String
  subdomain           String                  @unique
  address             String
  rcNumber            String?
  principalName       String
  establishmentYear   String
  totalStudents       Int?
  totalTeachers       Int?
  facilities          String[]
  accreditation       String?
  additionalInfo      String?
  status              SchoolApplicationStatus @default(PENDING)
  submittedBy         String
  submittedAt         DateTime                @default(now())
  reviewedAt          DateTime?
  reviewedBy          String?
  educationLevel      String
  lga                 String
  nemisId             String?
  officialPhone       String
  schoolEmail         String
  state               String
  stateApprovalNumber String?
  waecNecoNumber      String?
  schoolType          String
  submittedByUser     User                    @relation(fields: [submittedBy], references: [id], onDelete: Cascade)

  @@map("school_applications")
}

model Level {
  id             String          @id @default(cuid())
  name           String
  schoolId       String
  description    String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  classes        Class[]
  examTimetables ExamTimetable[]
  school         School          @relation(fields: [schoolId], references: [id])
  timetables     Timetable[]
  subjects       Subject[]       @relation("LevelToSubject")

  @@unique([name, schoolId])
  @@map("levels")
}

model Class {
  id                    String                @id @default(cuid())
  name                  String
  levelId               String
  schoolId              String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  supervisorId          String?
  level                 Level                 @relation(fields: [levelId], references: [id])
  school                School                @relation(fields: [schoolId], references: [id])
  supervisor            Teacher?              @relation("ClassSupervisor", fields: [supervisorId], references: [id])
  examTimetables        ExamTimetable[]
  studentApplications   StudentApplication[]
  students              Student[]
  teacherSubjectClasses TeacherSubjectClass[]
  timetables            Timetable[]

  @@unique([name, levelId, schoolId])
  @@map("classes")
}

model Subject {
  id                    String                @id @default(cuid())
  name                  String
  code                  String
  creditUnit            Int
  term                  Term
  isGeneral             Boolean               @default(false)
  schoolId              String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  classAssignment       String?
  examTimetables        ExamTimetable[]
  school                School                @relation(fields: [schoolId], references: [id])
  teacherSubjectClasses TeacherSubjectClass[]
  levels                Level[]               @relation("LevelToSubject")

  @@map("subjects")
}

model Teacher {
  id                          String                @id @default(cuid())
  name                        String
  email                       String                @unique
  phone                       String
  address                     String
  birthday                    String
  sex                         String
  img                         String
  teacherId                   String                @unique
  schoolId                    String
  userId                      String?               @unique
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  classesSupervised           Class[]               @relation("ClassSupervisor")
  examTimetablesAsInvigilator ExamTimetable[]       @relation("ExamTimetable_Invigilator")
  examTimetablesAsTeacher     ExamTimetable[]       @relation("ExamTimetable_Teacher")
  teacherSubjectClasses       TeacherSubjectClass[]
  school                      School                @relation(fields: [schoolId], references: [id])
  user                        User?                 @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@map("teachers")
}

model TeacherSubjectClass {
  id                   String   @id @default(cuid())
  teacherId            String
  subjectId            String
  classId              String
  schoolId             String
  isActive             Boolean  @default(true)
  assignedAt           DateTime @default(now())
  assignedBy           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  hoursPerWeek         Int      @default(1)
  requiresDoublePeriod Boolean  @default(false)
  class                Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject              Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher              Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId, classId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([classId])
  @@index([schoolId])
  @@map("teacher_subject_classes")
}

model Student {
  id                 String            @id @default(cuid())
  firstName          String
  lastName           String
  dob                String
  gender             String
  email              String            @unique
  phone              String
  address            String
  state              String
  lga                String
  religion           String
  classId            String
  schoolId           String
  className          String?
  parentName         String
  parentRelationship String
  parentEmail        String
  parentPhone        String
  parentOccupation   String?
  parentAddress      String?
  profileImagePath   String?
  agreeTerms         Boolean           @default(false)
  status             ApplicationStatus @default(PROGRESS)
  applicationNumber  String            @unique @default(cuid())
  applicationDate    DateTime          @default(now())
  userId             String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lastSchoolAttended String?
  class              Class             @relation(fields: [classId], references: [id])
  school             School            @relation(fields: [schoolId], references: [id])
  user               User?             @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([classId])
  @@map("students")
}

model Timetable {
  id        String   @id @default(cuid())
  classId   String
  levelId   String
  term      Term
  schedule  Json
  schoolId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  level     Level    @relation(fields: [levelId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([classId, term, schoolId])
  @@map("timetables")
}

model ExamTimetable {
  id            String   @id @default(cuid())
  subjectId     String
  teacherId     String
  invigilatorId String?
  examHall      String
  date          String
  startTime     String
  endTime       String
  term          Term
  classId       String
  levelId       String
  schoolId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  class         Class    @relation(fields: [classId], references: [id])
  invigilator   Teacher? @relation("ExamTimetable_Invigilator", fields: [invigilatorId], references: [id])
  level         Level    @relation(fields: [levelId], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  subject       Subject  @relation(fields: [subjectId], references: [id])
  teacher       Teacher  @relation("ExamTimetable_Teacher", fields: [teacherId], references: [id])

  @@map("exam_timetables")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetRoles Role[]
  createdBy   String
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [createdBy], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("announcements")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  startTime   String
  endTime     String
  date        String
  createdBy   String
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [createdBy], references: [id])
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("events")
}

model ScreeningSlot {
  id           String               @id @default(cuid())
  date         String
  startTime    String
  endTime      String?
  venue        String?
  maxCapacity  Int
  bookingCount Int                  @default(0)
  schoolId     String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  bookings     ApplicationBooking[]
  applications StudentApplication[]
  school       School               @relation(fields: [schoolId], references: [id])

  @@map("screening_slots")
}

model ApplicationBooking {
  id        String        @id @default(cuid())
  name      String
  email     String
  slotId    String
  schoolId  String
  createdAt DateTime      @default(now())
  school    School        @relation(fields: [schoolId], references: [id])
  slot      ScreeningSlot @relation(fields: [slotId], references: [id])

  @@map("application_bookings")
}

model StudentApplication {
  id                 String            @id @default(cuid())
  firstName          String
  lastName           String
  dob                String
  gender             String
  email              String
  phone              String?
  classId            String
  className          String?
  parentName         String
  parentRelationship String
  parentEmail        String
  parentPhone        String
  parentOccupation   String?
  parentAddress      String?
  profileImagePath   String?
  agreeTerms         Boolean           @default(false)
  status             ApplicationStatus @default(PROGRESS)
  applicationNumber  String            @unique @default(cuid())
  applicationDate    DateTime          @default(now())
  schoolId           String
  userId             String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  lastSchoolAttended String?
  address            String?
  lga                String?
  religion           String?
  state              String?
  screeningSlotId    String?
  class              Class             @relation(fields: [classId], references: [id])
  school             School            @relation(fields: [schoolId], references: [id])
  user               User?             @relation(fields: [userId], references: [id])
  screeningSlot      ScreeningSlot?    @relation(fields: [screeningSlotId], references: [id])

  @@map("student_applications")
}

model AcademicSession {
  id        String         @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean        @default(false)
  schoolId  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms     AcademicTerm[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("academic_sessions")
}

model AcademicTerm {
  id        String          @id @default(cuid())
  name      Term
  startDate DateTime
  endDate   DateTime
  sessionId String
  schoolId  String
  isActive  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    AcademicEvent[]
  school    School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([name, sessionId])
  @@index([sessionId])
  @@index([schoolId])
  @@map("academic_terms")
}

model AcademicEvent {
  id          String       @id @default(cuid())
  title       String
  type        EventType
  startDate   DateTime
  endDate     DateTime
  termId      String
  schoolId    String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term        AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@index([termId])
  @@index([schoolId])
  @@map("academic_events")
}

model TimetableConfig {
  id              String   @id @default(cuid())
  schoolId        String   @unique
  schoolStartTime String
  schoolEndTime   String
  periodDuration  Int
  breaks          Json
  workingDays     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("timetable_configs")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
  USER
}

enum Term {
  FIRST
  SECOND
  THIRD
}

enum ApplicationStatus {
  ADMITTED
  PROGRESS
  REJECTED
}

enum SchoolApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SchoolType {
  PUBLIC
  PRIVATE
  INTERNATIONAL
  FAITH_BASED
}

enum OwnershipType {
  GOVERNMENT
  PRIVATE
  RELIGIOUS
  COMMUNITY
}

enum CurriculumType {
  NATIONAL
  BRITISH
  AMERICAN
  IB
  MONTESSORI
  OTHER
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum EventType {
  HOLIDAY
  EXAM
  CA
  REVISION
  NORMAL_CLASS
  OTHER
}
